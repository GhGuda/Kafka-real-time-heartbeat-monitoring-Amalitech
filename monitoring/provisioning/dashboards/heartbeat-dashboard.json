{
  "title": "Real-Time Customer Heartbeat Monitoring",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Messages / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(heartbeat_messages_received_total[1m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Insert / sec",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(heartbeat_messages_inserted_total[1m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Consumer Lag",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "heartbeat_consumer_lag",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Error Rate (%)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "(rate(heartbeat_messages_invalid_total[1m]) / rate(heartbeat_messages_received_total[1m])) * 100",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Traffic Breakdown",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(heartbeat_messages_received_total[1m])",
          "legendFormat": "Received"
        },
        {
          "expr": "rate(heartbeat_messages_valid_total[1m])",
          "legendFormat": "Valid"
        },
        {
          "expr": "rate(heartbeat_messages_invalid_total[1m])",
          "legendFormat": "Invalid"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Consumer Lag Over Time",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "heartbeat_consumer_lag",
          "legendFormat": "Lag"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    }
  ]
}